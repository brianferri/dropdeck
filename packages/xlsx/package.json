{
    "name": "@dropdeck/xlsx",
    "version": "0.0.0",
    "description": "Type-level OOXML/SpreadsheetML specification and serializer for building .xlsx workbooks",
    "type": "module",
    "exports": {
        ".": "./dist/src/index.js",
        "./spreadsheetml": "./dist/src/spreadsheetml/index.js",
        "./package": "./dist/src/package/index.js",
        "./document": "./dist/src/document/index.js"
    },
    "dependencies": {
        "@dropdeck/xml": "*"
    },
    "scripts": {
        "check": "tsc --noEmit && eslint .",
        "build": "rm -rf dist && tsc",
        "test": "tsc --noEmit && node --test \"dist/tests/**/*.test.js\""
    },
    "author": "Brian Ferri",
    "license": "ISC",
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.5.0",
        "eslint": "^10.1.0",
        "eslint-plugin-jsdoc": "^63.0.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.57.2"
    }
}
