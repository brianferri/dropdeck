{
    "name": "@dropdeck/xml",
    "version": "0.0.0",
    "description": "Dependency-free, typed XML element tree and serializer, with dialects",
    "type": "module",
    "exports": {
        ".": "./dist/src/index.js",
        "./svg": "./dist/src/svg/index.js",
        "./mathml": "./dist/src/mathml/index.js",
        "./omml": "./dist/src/omml/index.js"
    },
    "scripts": {
        "check": "tsc --noEmit && eslint .",
        "build": "rm -rf dist && tsc",
        "test": "tsc --noEmit && node --test \"dist/tests/**/*.test.js\""
    },
    "dependencies": {
        "@dropdeck/common": "*"
    },
    "author": "Brian Ferri",
    "license": "ISC",
    "devDependencies": {
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^25.5.0",
        "eslint": "^10.1.0",
        "eslint-plugin-jsdoc": "^63.0.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.57.2"
    }
}
